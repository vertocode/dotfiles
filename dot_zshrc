# ------ GIT ALIASES ------
# Commit all changes with the provided message
alias commit='f() { git add . && git commit -m "$1"; }; f'
alias amend='git add . && git commit --amend --no-edit'
# Update local main branch
alias pull='git fetch origin main && git merge origin/main'
# Update main and push the current branch
alias push='git push origin HEAD'
alias fpush='git push origin HEAD --force-with-lease'
# Update main and create a new branch
alias new='f() { git fetch origin main && git checkout main && git reset --hard origin/main && git checkout -b "$1"; }; f'
# bun completions
[ -s "/Users/evertonvanoni/.bun/_bun" ] && source "/Users/evertonvanoni/.bun/_bun"

# ------ JUJUTSTU ALIASES -----
jclone() { jj git clone --colocate "$1"; }
alias jinit='jj git init --colocate'
alias jlog='jj log'
jbranch() { jj log -r "::@ ~ ::${1:-main}@origin"; }
jedit() { jj edit "$1"; }
jdescribe() { jj describe "${2:-@}" -m "$1"; }
# $1 = commit message, $2 bookmark name / branch name.
jnewmain() { jj git fetch && jj new main -m "$1" && jj bookmark create "$2"; }
jnewcurrent() { jj git fetch && jj new @ -m "$1" && jj bookmark create "$2"; }
# $1 = from branch, $2 = commit message, $3 = new bookmark name
jnewfrom() {
  if [[ -z "$1" || -z "$2" || -z "$3" ]]; then
    echo "Usage: jnewfrom <from-branch> <commit-message> <new-branch-name>"
    return 1
  fi
  jj git fetch && jj new "$1" -m "$2" && jj bookmark create "$3"
}
jcommit() { jj new @ -m "$1"; }
jdiff() {
  local BOOKMARK
  BOOKMARK=$(jj log -r @ --no-graph --template 'bookmarks.join(" ")')
  BOOKMARK=${BOOKMARK%% *}
  BOOKMARK=${BOOKMARK%\*}
  if [[ -z "$BOOKMARK" ]]; then
    print -u2 "jdiff: no bookmark found on @"
    return 1
  fi
  jj diff --from "$BOOKMARK" --to "$BOOKMARK@origin"
}          
jrestore() {
  local BOOKMARK
  BOOKMARK=$(jj log -r @ --no-graph --template 'bookmarks.join(" ")')
  BOOKMARK=${BOOKMARK%% *}
  BOOKMARK=${BOOKMARK%\*}
  if [[ -z "$BOOKMARK" ]]; then
    print -u2 "jdiff: no bookmark found on @"
    return 1
  fi
  jj restore --from "$BOOKMARK@origin"
}      
jpush() {
  if [[ -n "$1" ]]; then
    jj git push --bookmark "$1"
  else
    jj git push --all --deleted
  fi
}
jtrack() { jj bookmark track "$1" --remote=origin; }
juntrack() { jj bookmark untrack "$1"; }
alias jfetch='jj git fetch --all-remotes'
jdelete() { jj bookmark delete "$1"; }
alias jsquash='jj squash'
#   ::@ | ::bookmarks()  — all ancestors of @ and of local bookmarks
#   ~ ::main@$remote     — exclude commits already on main (keeps only local work)
#   & mutable()          — exclude immutable commits so -s doesn't try to rewrite
#                          commits that were pushed by others or already merged
#   roots(...)           — pick the base of each remaining chain; paired with -s so
#                          the entire stack is rebased together preserving parent-
#                          child structure (-r would flatten all commits onto main)
#   --skip-emptied       - drops empty commits; useful after landing a PR from a stack on main and rebasing
#                          it is like auto-dropping commits.
alias jrebase='jj rebase -s "roots(((::@ | ::bookmarks()) ~ ::main@origin) & mutable())" -d "main@origin" --skip-emptied'
# Rebase mutable stack onto the latest remote of the parent branch.
# Auto-detects the base (e.g. a teammate's branch), falling back to main@origin.
jrebaseparent() {
  jj git fetch

  # Find the change ID of the most recent conflicted mutable ancestor of @.
  # Used to identify the parent feature branch even when local state is
  # divergent/conflicted (e.g. someone force-pushed the parent branch).
  local conflict_change_id
  conflict_change_id=$(jj log \
    -r "latest(::@ & mutable() & conflicts())" \
    --no-graph \
    --template 'change_id.short()' \
    2>/dev/null | xargs)

  # Reset all conflicted local bookmarks to their remote state so the
  # parent branch reflects what everyone else is working from.
  local conflicted_bookmarks
  conflicted_bookmarks=$(jj log -r 'bookmarks() & conflicts()' --no-graph \
    --template 'bookmarks.map(|b| b.name()).join("\n")' 2>/dev/null)
  if [[ -n "$conflicted_bookmarks" ]]; then
    while IFS= read -r bm; do
      [[ -z "$bm" ]] && continue
      if jj log -r "${bm}@origin" --no-graph 2>/dev/null | grep -q .; then
        echo "jrebaseparent: restoring ${bm} to ${bm}@origin"
        jj bookmark set "${bm}" -r "${bm}@origin"
      fi
    done <<< "$conflicted_bookmarks"
  fi

  # Detect destination: prefer the nearest non-main remote bookmark that
  # descends from the conflicted ancestor's change ID. This correctly
  # identifies the parent feature branch even when its local copy was stale.
  local dest
  if [[ -n "$conflict_change_id" ]]; then
    dest=$(jj log \
      -r "latest((remote_bookmarks() ~ main@origin ~ ancestors(main@origin)) & descendants(${conflict_change_id}))" \
      --no-graph \
      --template 'remote_bookmarks.filter(|b| b.remote() == "origin" && b.name() != "main").map(|b| b.name() ++ "@origin").join("")' \
      2>/dev/null | xargs)
  fi

  # Fallback: standard detection via mutable root parents
  if [[ -z "$dest" ]]; then
    dest=$(jj log \
      -r "parents(roots(((::@ | ::bookmarks()) ~ ::main@origin) & mutable()))" \
      --no-graph \
      --template 'remote_bookmarks.filter(|b| b.remote() == "origin").map(|b| b.name() ++ "@origin").join("")' \
      2>/dev/null | xargs)
  fi

  if [[ -z "$dest" ]]; then
    dest="main@origin"
  fi

  echo "jrebaseparent: rebasing onto ${dest}"

  # Rebase only commits unique to this branch: non-conflicted, mutable commits
  # not already reachable from dest. This takes all of dest (from remote) and
  # stacks only the children branch's actual work on top — skipping the stale
  # conflicted ancestor commits from the parent branch.
  local rebase_root
  rebase_root=$(jj log \
    -r "roots((::@ & mutable() & ~conflicts()) ~ ::${dest})" \
    --no-graph \
    --template 'change_id' \
    2>/dev/null | head -1 | xargs)

  if [[ -n "$rebase_root" ]]; then
    jj rebase -s "${rebase_root}" -d "${dest}" --skip-emptied
  else
    echo "jrebaseparent: nothing to rebase, already up to date"
  fi
}

# ------ CUSTOM SCRIPTS (Rust) ------
alias repo-clean='$HOME/scripts/repo-clean/target/release/repo-clean'
repo() {
  local bin="$HOME/scripts/repo-open/target/release/repo-open"
  if [[ ! -x "$bin" ]]; then
    echo "repo-open binary not found. Build it first:"
    echo "  cd ~/scripts/repo-open && cargo build --release"
    echo ""
    echo "If Rust is not installed:"
    echo "  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh"
    echo "  . \"\$HOME/.cargo/env\" && cd ~/scripts/repo-open && cargo build --release"
    return 1
  fi
  local dir
  dir=$("$bin" "$1") || return 1
  cd "$dir" || return 1
}
alias portcheck='$HOME/scripts/portcheck/target/release/portcheck'

